<footer class="site-footer mt-auto">
  <div class="container">
    <div class="row g-4 py-4">

      <div class="col-md-4">
        <div class="d-flex align-items-center gap-2 mb-2">
          <div class="brand-icon brand-icon-sm">
            <i class="fas fa-terminal"></i>
          </div>
          <span class="text-white fw-bold fs-5">TechBlog</span>
        </div>
        <p class="text-muted small mb-0">
          A place for developers to learn, share, and grow.
          Covering DevOps, Cloud, Containers and modern dev practices.
        </p>
      </div>

      <div class="col-md-4">
        <h6 class="text-white fw-semibold mb-3">Categories</h6>
        <ul class="list-unstyled footer-links mb-0">
          <li><a href="/?category=DevOps"><i class="fas fa-chevron-right me-1 text-primary small"></i>DevOps</a></li>
          <li><a href="/?category=Docker"><i class="fas fa-chevron-right me-1 text-primary small"></i>Docker</a></li>
          <li><a href="/?category=Kubernetes"><i class="fas fa-chevron-right me-1 text-primary small"></i>Kubernetes</a></li>
          <li><a href="/?category=General"><i class="fas fa-chevron-right me-1 text-primary small"></i>General</a></li>
        </ul>
      </div>

      <div class="col-md-4">
        <h6 class="text-white fw-semibold mb-3">Quick Links</h6>
        <ul class="list-unstyled footer-links mb-0">
          <% if (user && user.role === 'admin') { %>
            <li><a href="/admin"><i class="fas fa-chevron-right me-1 text-primary small"></i>Admin Dashboard</a></li>
            <li><a href="/admin/posts/create"><i class="fas fa-chevron-right me-1 text-primary small"></i>New Post</a></li>
            <li><a href="/auth/logout"><i class="fas fa-chevron-right me-1 text-primary small"></i>Logout</a></li>
          <% } else if (user && user.role === 'user') { %>
            <li><a href="/dashboard"><i class="fas fa-chevron-right me-1 text-primary small"></i>My Dashboard</a></li>
            <li><a href="/auth/logout"><i class="fas fa-chevron-right me-1 text-primary small"></i>Logout</a></li>
          <% } else { %>
            <li><a href="/auth/login"><i class="fas fa-chevron-right me-1 text-primary small"></i>Login</a></li>
          <% } %>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="text-muted small mb-0">
        &copy; <%= new Date().getFullYear() %> TechBlog &mdash; Built with
        <i class="fas fa-heart text-danger mx-1"></i> using Node.js, Express &amp; SQLite
      </p>
    </div>
  </div>
</footer>

<!-- Bootstrap JS bundle (includes Popper) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- Custom JS -->
<script src="/js/main.js"></script>
</body>
</html>
