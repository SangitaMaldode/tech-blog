<nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
  <div class="container">

    <!-- Brand Logo -->
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <div class="brand-icon">
        <i class="fas fa-terminal"></i>
      </div>
      TechBlog
    </a>

    <!-- Mobile Toggle -->
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">

      <!-- Left Links -->
      <ul class="navbar-nav me-auto gap-1">
        <li class="nav-item">
          <a class="nav-link" href="/">
            <i class="fas fa-home me-1 opacity-75"></i>Home
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/?category=DevOps">
            <i class="fas fa-infinity me-1 opacity-75"></i>DevOps
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/?category=Docker">
            <i class="fab fa-docker me-1 opacity-75"></i>Docker
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/?category=Kubernetes">
            <i class="fas fa-dharmachakra me-1 opacity-75"></i>Kubernetes
          </a>
        </li>
      </ul>

      <!-- Search -->
      <form class="d-flex me-3 search-form" action="/" method="GET">
        <div class="input-group input-group-sm">
          <input class="form-control search-input" type="search" name="search"
                 placeholder="Search posts..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
          <button class="btn btn-primary" type="submit">
            <i class="fas fa-search"></i>
          </button>
        </div>
      </form>

