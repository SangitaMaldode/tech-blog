<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- ─── User Welcome Banner ──────────────────────────────────────────────── -->
<section class="user-hero">
  <div class="container">
    <div class="row align-items-center g-4">

      <!-- Welcome -->
      <div class="col-md-7">
        <div class="d-flex align-items-center gap-3 mb-2">
          <div class="author-avatar author-avatar-lg">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="text-muted small mb-0">Welcome back</p>
            <h2 class="text-white fw-bold mb-0"><%= user.username %></h2>
            <span class="role-badge role-user">
              <i class="fas fa-user me-1"></i>Reader
            </span>
          </div>
        </div>
        <p class="text-muted mt-3 mb-0">
          Browse all published technical articles below. Use the search or category filter to find what you need.
        </p>
      </div>

      <!-- Quick Stats -->
      <div class="col-md-5">
        <div class="row g-3">
          <div class="col-6">
            <div class="user-stat-card">
              <div class="user-stat-icon text-primary">
                <i class="fas fa-newspaper"></i>
              </div>
              <div class="user-stat-number"><%= stats.totalPosts %></div>
              <div class="user-stat-label">Published Articles</div>
            </div>
          </div>
          <div class="col-6">
            <div class="user-stat-card">
              <div class="user-stat-icon text-success">
                <i class="fas fa-layer-group"></i>
              </div>
              <div class="user-stat-number"><%= stats.totalCategories %></div>
              <div class="user-stat-label">Categories</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ─── Main Content ─────────────────────────────────────────────────────── -->
<div class="container py-5">

  <!-- Flash Messages -->
  <% if (success && success.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
      <i class="fas fa-circle-check"></i><span><%= success[0] %></span>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
      <i class="fas fa-circle-xmark"></i><span><%= error[0] %></span>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <div class="row g-4">

    <!-- Posts Column -->
    <div class="col-lg-8">

      <!-- Search Bar -->
      <form action="/dashboard" method="GET" class="mb-4">
        <div class="input-group">
          <input class="form-control dark-input" type="search" name="search"
                 placeholder="Search articles..." value="<%= searchQuery %>">
          <% if (selectedCategory) { %>
            <input type="hidden" name="category" value="<%= selectedCategory %>">
          <% } %>
          <button class="btn btn-primary" type="submit">
            <i class="fas fa-search me-1"></i>Search
          </button>
          <% if (searchQuery || selectedCategory) { %>
            <a href="/dashboard" class="btn btn-outline-secondary">
              <i class="fas fa-xmark"></i> Clear
            </a>
          <% } %>
        </div>
      </form>

      <!-- Active filter label -->
      <% if (selectedCategory || searchQuery) { %>
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
          <span class="text-muted small">Filtered by:</span>
          <% if (selectedCategory) { %>
            <span class="filter-tag">
              <i class="fas fa-tag me-1"></i><%= selectedCategory %>
            </span>
          <% } %>
          <% if (searchQuery) { %>
            <span class="filter-tag">
              <i class="fas fa-search me-1"></i>&ldquo;<%= searchQuery %>&rdquo;
            </span>
          <% } %>
        </div>
      <% } %>

      <!-- Section Heading -->
      <div class="d-flex align-items-center justify-content-between mb-4">
        <h5 class="text-white fw-semibold mb-0">
          <i class="fas fa-newspaper me-2 text-primary"></i>
          <%= selectedCategory ? selectedCategory + ' Articles' : searchQuery ? 'Search Results' : 'All Articles' %>
          <span class="text-muted fw-normal small ms-2">(<%= posts.length %>)</span>
        </h5>
      </div>

      <!-- Posts Grid -->
      <% if (posts.length === 0) { %>
        <div class="text-center py-5">
          <i class="fas fa-magnifying-glass text-muted mb-3" style="font-size:3rem"></i>
          <h5 class="text-muted">No articles found</h5>
          <p class="text-muted small">Try a different search or category.</p>
          <a href="/dashboard" class="btn btn-primary btn-sm mt-2">View All Articles</a>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% posts.forEach(post => { %>
            <div class="col-md-6">
              <article class="blog-card h-100">
                <div class="blog-card-body">
                  <div class="mb-3">
                    <span class="category-badge"><%= post.category %></span>
                  </div>
                  <h2 class="blog-card-title">
                    <a href="/post/<%= post.slug %>"><%= post.title %></a>
                  </h2>
                  <p class="blog-card-excerpt"><%= post.excerpt %></p>
                </div>
                <div class="blog-card-footer">
                  <div class="d-flex align-items-center gap-2">
                    <div class="author-avatar author-avatar-sm">
                      <%= post.author_name.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                      <div class="text-white small fw-medium"><%= post.author_name %></div>
                      <div class="text-muted" style="font-size:0.72rem">
                        <i class="fas fa-calendar-alt me-1"></i>
                        <%= new Date(post.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
                      </div>
                    </div>
                  </div>
                  <a href="/post/<%= post.slug %>" class="btn-read-more">
                    Read <i class="fas fa-arrow-right ms-1"></i>
                  </a>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">

      <!-- Account Info -->
      <div class="widget mb-4">
        <h5 class="widget-title">
          <i class="fas fa-circle-user me-2 text-primary"></i>My Account
        </h5>
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="author-avatar" style="width:44px;height:44px;font-size:1.1rem">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <div>
            <div class="text-white fw-semibold"><%= user.username %></div>
            <div class="text-muted small"><%= user.email %></div>
          </div>
        </div>
        <div class="d-flex gap-2">
          <span class="role-badge role-user w-100 justify-content-center">
            <i class="fas fa-user me-1"></i>Reader Role
          </span>
        </div>
        <hr class="border-secondary my-3">
        <a href="/auth/logout" class="btn btn-outline-danger btn-sm w-100">
          <i class="fas fa-right-from-bracket me-1"></i>Logout
        </a>
      </div>

      <!-- Category Filter -->
      <div class="widget mb-4">
        <h5 class="widget-title">
          <i class="fas fa-layer-group me-2 text-primary"></i>Browse by Category
        </h5>
        <ul class="list-unstyled mb-0">
          <li>
            <a href="/dashboard" class="category-link <%= !selectedCategory ? 'active' : '' %>">
              <i class="fas fa-border-all me-2"></i>All Articles
            </a>
          </li>
          <% categories.forEach(cat => { %>
            <li>
              <a href="/dashboard?category=<%= cat.category %>"
                 class="category-link <%= selectedCategory === cat.category ? 'active' : '' %>">
                <i class="fas fa-chevron-right me-2 text-primary small"></i><%= cat.category %>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>

      <!-- Tags -->
      <div class="widget">
        <h5 class="widget-title">
          <i class="fas fa-tags me-2 text-primary"></i>Popular Tags
        </h5>
        <div class="d-flex flex-wrap gap-2">
          <% ['docker','kubernetes','devops','cicd','jenkins','containers','linux','cloud'].forEach(tag => { %>
            <a href="/dashboard?search=<%= tag %>" class="tag-chip"><%= tag %></a>
          <% }) %>
        </div>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
