<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- ─── Post Header ──────────────────────────────────────────────────────── -->
<section class="post-hero">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="mb-3">
          <a href="/?category=<%= post.category %>" class="category-badge me-2"><%= post.category %></a>
          <% if (post.tags) { %>
            <% post.tags.split(',').slice(0,3).forEach(tag => { %>
              <span class="tag-chip tag-chip-sm"><%= tag.trim() %></span>
            <% }) %>
          <% } %>
        </div>
        <h1 class="post-hero-title"><%= post.title %></h1>
        <p class="post-hero-excerpt"><%= post.excerpt %></p>
        <div class="d-flex align-items-center gap-3 mt-4">
          <div class="author-avatar author-avatar-lg">
            <%= post.author_name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <div class="text-white fw-semibold"><%= post.author_name %></div>
            <div class="text-muted small">
              <i class="fas fa-calendar-alt me-1"></i>
              Published <%= new Date(post.created_at).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %>
              <% if (post.updated_at !== post.created_at) { %>
                &bull; Updated <%= new Date(post.updated_at).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %>
              <% } %>
            </div>
          </div>
          <% if (user) { %>
            <div class="ms-auto">
              <a href="/admin/posts/edit/<%= post.id %>" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-pen me-1"></i>Edit Post
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Post Content ─────────────────────────────────────────────────────── -->
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Article Body (Markdown rendered to HTML by the route handler) -->
      <article class="post-content">
        <%- markedContent %>
      </article>

      <!-- Tags Footer -->
      <% if (post.tags) { %>
        <div class="d-flex align-items-center gap-2 mt-5 pt-4 border-top border-dark-subtle flex-wrap">
          <span class="text-muted small fw-medium">Tags:</span>
          <% post.tags.split(',').forEach(tag => { %>
            <a href="/?search=<%= tag.trim() %>" class="tag-chip"><%= tag.trim() %></a>
          <% }) %>
        </div>
      <% } %>

      <!-- Nav: back to blog -->
      <div class="mt-5">
        <a href="/" class="btn btn-outline-secondary">
          <i class="fas fa-arrow-left me-2"></i>Back to Blog
        </a>
      </div>

    </div>
  </div>
</div>

<!-- ─── Related Posts ────────────────────────────────────────────────────── -->
<% if (relatedPosts.length > 0) { %>
  <section class="related-section py-5">
    <div class="container">
      <h3 class="text-white fw-bold mb-4">
        <i class="fas fa-newspaper me-2 text-primary"></i>Related Articles
      </h3>
      <div class="row g-4">
        <% relatedPosts.forEach(rp => { %>
          <div class="col-md-4">
            <article class="blog-card h-100">
              <div class="blog-card-body">
                <span class="category-badge mb-3 d-inline-block"><%= rp.category %></span>
                <h5 class="blog-card-title">
                  <a href="/post/<%= rp.slug %>"><%= rp.title %></a>
                </h5>
                <p class="blog-card-excerpt small"><%= rp.excerpt %></p>
              </div>
              <div class="blog-card-footer">
                <span class="text-muted small">
                  <%= new Date(rp.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
                </span>
                <a href="/post/<%= rp.slug %>" class="btn-read-more">
                  Read <i class="fas fa-arrow-right ms-1"></i>
                </a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<%- include('../partials/footer') %>
