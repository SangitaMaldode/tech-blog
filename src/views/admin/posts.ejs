<%- include('../partials/head') %>

<div class="admin-layout">
  <%- include('./sidebar', { activePage: 'posts' }) %>

  <main class="admin-main">

    <div class="admin-topbar">
      <div>
        <h4 class="text-white fw-bold mb-0">All Posts</h4>
        <p class="text-muted small mb-0">Manage your blog articles</p>
      </div>
      <a href="/admin/posts/create" class="btn btn-primary btn-sm">
        <i class="fas fa-plus me-1"></i>New Post
      </a>
    </div>

    <div class="admin-content">

      <!-- Flash Messages -->
      <% if (success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
          <i class="fas fa-circle-check"></i><span><%= success[0] %></span>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
          <i class="fas fa-circle-xmark"></i><span><%= error[0] %></span>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <div class="admin-card">
        <div class="table-responsive">
          <table class="table admin-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Title</th>
                <th>Category</th>
                <th>Author</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (posts.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted py-5">
                    <i class="fas fa-inbox mb-2" style="font-size:2rem;display:block"></i>
                    No posts yet. <a href="/admin/posts/create" class="text-primary">Create your first post</a>
                  </td>
                </tr>
              <% } %>
              <% posts.forEach((post, i) => { %>
                <tr>
                  <td class="text-muted small"><%= i + 1 %></td>
                  <td>
                    <span class="text-white fw-medium"><%= post.title %></span>
                    <div class="text-muted" style="font-size:0.75rem;font-family:var(--font-mono)">/post/<%= post.slug %></div>
                  </td>
                  <td><span class="category-badge-sm"><%= post.category %></span></td>
                  <td class="text-muted small"><%= post.author_name %></td>
                  <td>
                    <% if (post.status === 'published') { %>
                      <span class="status-badge status-published">
                        <i class="fas fa-circle me-1" style="font-size:0.4rem;vertical-align:middle"></i>Published
                      </span>
                    <% } else { %>
                      <span class="status-badge status-draft">
                        <i class="fas fa-circle me-1" style="font-size:0.4rem;vertical-align:middle"></i>Draft
                      </span>
                    <% } %>
                  </td>
                  <td class="text-muted small">
                    <%= new Date(post.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <!-- View (only if published) -->
                      <% if (post.status === 'published') { %>
                        <a href="/post/<%= post.slug %>" target="_blank"
                           class="btn btn-xs btn-outline-secondary" title="View post">
                          <i class="fas fa-eye"></i>
                        </a>
                      <% } %>
                      <!-- Edit -->
                      <a href="/admin/posts/edit/<%= post.id %>"
                         class="btn btn-xs btn-outline-primary" title="Edit post">
                        <i class="fas fa-pen"></i>
                      </a>
                      <!-- Delete -->
                      <form action="/admin/posts/delete/<%= post.id %>" method="POST"
                            onsubmit="return confirm('Delete \'<%= post.title.replace(/'/g, '') %>\'? This cannot be undone.')">
                        <button type="submit" class="btn btn-xs btn-outline-danger" title="Delete post">
                          <i class="fas fa-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>

<%- include('../partials/footer') %>
