# ─────────────────────────────────────────────
# TechBlog Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Session (change this to a long random string in production!)
SESSION_SECRET=my-super-secret-session-key-change-this

# Database path (SQLite file location)
DATABASE_PATH=./data/blog.db

# Default Admin User (created on first run)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@techblog.com
ADMIN_PASSWORD=Admin@123

# Default Regular User (created on first run)
USER_USERNAME=user
USER_EMAIL=user@techblog.com
USER_PASSWORD=User@123
